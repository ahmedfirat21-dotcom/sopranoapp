{
  "outputDirectory": "public",
  "buildCommand": "",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy-policy.html" },
    { "source": "/terms", "destination": "/terms-of-service.html" }
  ]
}
