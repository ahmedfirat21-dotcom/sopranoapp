{
  "cli": {
    "version": ">= 14.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "googleServicesFile": "./google-services.json"
      },
      "env": {
        "GOOGLE_SERVICES_JSON": "./google-services.json"
      }
    },
    "production": {}
  },
  "submit": {
    "production": {}
  }
}
