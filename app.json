{
  "expo": {
    "name": "SopranoChat",
    "slug": "SopranoChat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sopranochat",
    "splash": {
      "image": "./assets/splash_s.png",
      "resizeMode": "contain",
      "backgroundColor": "#07080A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sopranochat.app",
      "bitcode": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07080A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.sopranochat.mobil2",
      "softwareKeyboardLayoutMode": "pan",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "sopranochat.app",
              "pathPrefix": "/room"
            },
            {
              "scheme": "https",
              "host": "sopranochat.app",
              "pathPrefix": "/user"
            },
            {
              "scheme": "https",
              "host": "sopranochat.app",
              "pathPrefix": "/event"
            },
            {
              "scheme": "sopranochat"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@config-plugins/react-native-webrtc",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#14B8A6",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı ve gönderi resmi yüklemek için galeri erişimi gerekiyor.",
          "cameraPermission": "Profil fotoğrafı çekmek için kamera erişimi gerekiyor."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bbd97aec-9d58-426f-8acc-215b24ff286a"
      }
    },
    "owner": "sopranochat"
  }
}
